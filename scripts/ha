#!/usr/bin/env bash
# ha — tiny wrapper around the Home Assistant REST API.
#
# Uses the environment-provided credentials so you can hit the API without
# re-typing the token or base URL:
#   HOMEASSISTANT_BASE_URL   e.g. https://ha.nmteaco.com
#   HOMEASSISTANT_TOKEN      long-lived access token (JWT)
#
# Usage:
#   scripts/ha <path> [curl-args...]
#
# Examples:
#   scripts/ha /api/                       # health check
#   scripts/ha /api/config                 # instance config
#   scripts/ha /api/states                 # all entity states
#   scripts/ha /api/states/sun.sun         # one entity
#   scripts/ha /api/services/light/turn_on -X POST \
#       -H 'Content-Type: application/json' -d '{"entity_id":"light.example"}'
set -euo pipefail

: "${HOMEASSISTANT_BASE_URL:?HOMEASSISTANT_BASE_URL is not set}"
: "${HOMEASSISTANT_TOKEN:?HOMEASSISTANT_TOKEN is not set}"

if [[ $# -lt 1 ]]; then
  echo "usage: scripts/ha <path> [curl-args...]" >&2
  echo "example: scripts/ha /api/" >&2
  exit 2
fi

path="$1"; shift
# Allow either "/api/..." or a full URL.
case "$path" in
  http://*|https://*) url="$path" ;;
  /*)                 url="${HOMEASSISTANT_BASE_URL%/}${path}" ;;
  *)                  url="${HOMEASSISTANT_BASE_URL%/}/${path}" ;;
esac

# The tunnel occasionally drops a request (brief cloudflared reconnect, HA core
# reload, edge blip). Retry transient failures with backoff so callers see the
# flakiness as, at worst, a slightly slower call instead of a hard error.
# curl's --retry already covers the transient HTTP statuses the tunnel emits
# (502/503/504) and, with --retry-connrefused, a refused origin during an HA
# reload — without wastefully retrying genuine 4xx client errors.
curl -fsS \
  --connect-timeout 10 --max-time 60 \
  --retry 4 --retry-delay 1 --retry-connrefused \
  -H "Authorization: Bearer ${HOMEASSISTANT_TOKEN}" \
  -H "Content-Type: application/json" \
  "$@" \
  "$url"
